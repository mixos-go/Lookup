{
  "$schema": "https://railway.app/railway.schema.json",
  "services": [
    {
      "name": "Postgres",
      "source": {
        "image": "postgres:17-alpine"
      },
      "variables": {
        "POSTGRES_USER": "lookup",
        "POSTGRES_PASSWORD": "${{secret}}",
        "POSTGRES_DB": "lookup",
        "DATABASE_URL": "postgresql://${{POSTGRES_USER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_PRIVATE_DOMAIN}}:5432/${{POSTGRES_DB}}"
      },
      "volumes": [
        {
          "mountPath": "/var/lib/postgresql/data",
          "size": 10
        }
      ]
    },
    {
      "name": "Redis",
      "source": {
        "image": "redis:8.2.1"
      },
      "variables": {
        "REDIS_URL": "redis://${{RAILWAY_PRIVATE_DOMAIN}}:6379"
      }
    },
    {
      "name": "Nginx Proxy Manager",
      "source": {
        "image": "jlesage/nginx-proxy-manager"
      },
      "volumes": [
        {
          "mountPath": "/config",
          "size": 1
        }
      ]
    },
    {
      "name": "Lookup",
      "source": {
        "repo": "mixos-go/Lookup",
        "branch": "main"
      },
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile",
        "rootDirectory": "/apps/backend"
      },
      "deploy": {
        "startCommand": "npx prisma migrate deploy && node dist/index.js",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 60,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "variables": {
        "DATABASE_URL": "${{Postgres.DATABASE_URL}}",
        "REDIS_URL": "${{Redis.REDIS_URL}}",
        "NODE_ENV": "production",
        "PORT": "3000",
        "JWT_SECRET": "${{secret}}",
        "JWT_REFRESH_SECRET": "${{secret}}",
        "ENCRYPTION_KEY": "${{secret}}",
        "CORS_ORIGIN": "*",
        "API_BASE_URL": "https://${{RAILWAY_PUBLIC_DOMAIN}}",
        "SHOPEE_PARTNER_ID": "",
        "SHOPEE_PARTNER_KEY": "",
        "TIKTOK_APP_KEY": "",
        "TIKTOK_APP_SECRET": ""
      },
      "networking": {
        "serviceDomain": {
          "port": 3000
        }
      }
    }
  ]
}
