# ══════════════════════════════════════════════════════════════════════════════
# LookUp — Environment Variables
# Salin file ini ke apps/backend/.env untuk development lokal
# ══════════════════════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# URL publik backend ini — dipakai untuk OAuth redirect URI
# Railway: isi dengan domain Railway, contoh: https://lookup-api.up.railway.app
API_BASE_URL=http://localhost:3000

# CORS origin — URL frontend/mobile dev server
# Railway: bisa isi dengan * atau domain spesifik
CORS_ORIGIN=*

# ─── Database ─────────────────────────────────────────────────────────────────
# Local: pakai docker-compose.yml
DATABASE_URL=postgresql://lookup:lookup_dev@localhost:5432/lookup_db

# Railway: JANGAN isi manual — pakai reference variable di Railway dashboard:
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local: pakai docker-compose.yml
REDIS_URL=redis://localhost:6379

# Railway: JANGAN isi manual — pakai reference variable:
# REDIS_URL=${{Redis.REDIS_URL}}

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti_dengan_64_char_random_hex_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=ganti_dengan_64_char_random_hex_berbeda_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Encryption (untuk access_token OAuth di database) ────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# HARUS 64 karakter hex (= 32 bytes)
ENCRYPTION_KEY=ganti_dengan_64_char_hex_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Shopee Partner API ────────────────────────────────────────────────────────
# Daftar di: https://open.shopee.com
# Menu: My Apps → Create App → dapat partner_id dan partner_key
SHOPEE_PARTNER_ID=123456
SHOPEE_PARTNER_KEY=your_partner_key_here

# ─── TikTok Shop Open API ─────────────────────────────────────────────────────
# Daftar di: https://partner.tiktokshop.com
# Menu: Apps → Create App → dapat App Key dan App Secret
TIKTOK_APP_KEY=your_tiktok_app_key
TIKTOK_APP_SECRET=your_tiktok_app_secret

# ─── VPS Only (tidak dipakai di Railway) ──────────────────────────────────────
POSTGRES_USER=lookup
POSTGRES_PASSWORD=ganti_dengan_password_kuat
POSTGRES_DB=lookup_prod

# ─── Mobile (Expo) ────────────────────────────────────────────────────────────
# Taruh di apps/mobile/.env
# Railway: isi EXPO_PUBLIC_API_URL dengan domain backend Railway
EXPO_PUBLIC_API_URL=http://localhost:3000
