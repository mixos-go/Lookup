# ─── Backend ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Database (Docker default)
DATABASE_URL=postgresql://lookup:lookup_dev@localhost:5432/lookup_db

# Redis (Docker default)
REDIS_URL=redis://localhost:6379

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_min_32_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_different_from_jwt_secret_xxxxxxxxxxxxxxxxxx

# Encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=64_hex_chars_here_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS
CORS_ORIGIN=*
API_BASE_URL=http://localhost:3000

# Shopee — Register at open.shopee.com
SHOPEE_PARTNER_ID=your_partner_id
SHOPEE_PARTNER_KEY=your_partner_key

# TikTok Shop — Register at partner.tiktokshop.com
TIKTOK_APP_KEY=your_app_key
TIKTOK_APP_SECRET=your_app_secret

# ─── Mobile ───────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000
