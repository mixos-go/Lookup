# apps/mobile/.env
# Hanya variabel berprefix EXPO_PUBLIC_ yang ter-bundle ke app — JANGAN taruh secret di sini

EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Testing di HP fisik via Expo Go ───────────────────────────────────────────
# 'localhost' = merujuk ke HP itu sendiri, BUKAN laptop kamu — tidak akan connect!
# Solusi: pakai IP address laptop di jaringan WiFi yang sama.
#
# Cara cek IP laptop:
#   macOS/Linux : ifconfig | grep "inet " (cari yang 192.168.x.x)
#   Windows     : ipconfig (cari "IPv4 Address")
#
# Contoh:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
#
# Syarat: laptop dan HP harus di WiFi yang SAMA, dan firewall laptop
# tidak memblokir port 3000.
